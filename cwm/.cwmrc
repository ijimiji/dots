fontname "Iosevka:size=20"

gap 37 1 0 0
command config "xterm -fa Iosevka -fs 24 -e emacs ~/.cwmrc"
command firefox "firefox"
command zathura "zathura"
command terminal "xterm -fa Iosevka -fs 14"
command nnn "xterm -fa Iosevka -fs 24 -e nnn"
command emacs "xterm -fa Iosevka -fs 24 -e emacs"
command ncmpcpp "xterm -fa Iosevka -fs 24 -e ncmpcpp"
command russian "setxkbmap -layout us,ru -option 'grp:toggle,grp_led:scroll'"
command belarusian "setxkbmap -layout us,by -option 'grp:toggle,grp_led:scroll'"
command suspend "sudo zzz"
command poweroff "sudo poweroff"

borderwidth 3
color activeborder "#ebcb8b"
color inactiveborder "#a3be8c"

color font "#ebcb8b"
color selfont "#2e3440"
color menubg "#2e3440"
color menufg "#ebcb8b"

unbind-key all

sticky yes
bind-key S4-q quit
bind-key S4-r restart
bind-key 4-l window-htile
bind-key 4-j window-vtile

bind-key 4-Tab window-cycle
bind-key S4-Tab window-rcycle

bind-key 4-1 group-only-1
bind-key 4-2 group-only-2
bind-key 4-3 group-only-3
bind-key 4-4 group-only-4
bind-key 4-5 group-only-5

bind-key 4C-1 group-toggle-1
bind-key 4C-2 group-toggle-2
bind-key 4C-3 group-toggle-3
bind-key 4C-4 group-toggle-4
bind-key 4-0 group-toggle-all
bind-key 4S-1 window-movetogroup-1
bind-key 4S-1 window-movetogroup-1
bind-key 4S-2 window-movetogroup-2
bind-key 4S-3 window-movetogroup-3
bind-key 4S-4 window-movetogroup-4
bind-key 4S-5 window-movetogroup-5
bind-key 4S-Return "xterm -e tmux"
bind-key 4S-c window-close
bind-key 4-Return menu-window
bind-key 4-space menu-exec

unbind-mouse all
bind-mouse "1" menu-cmd
bind-mouse "3" menu-window

bind-mouse 4-3 window-resize
bind-mouse 4S-2 window-close
bind-mouse 4-1 window-move
bind-mouse 4S-1 window-vtile
bind-mouse 4S-3 window-htile
bind-mouse 4-2 window-maximize
